APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Use false in production.
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Tokyo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lom-sales-hub
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=180
# Production: consider SESSION_ENCRYPT=true (encrypts session payload at rest).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Security ---
# Self-service registration: off when APP_ENV=production unless you set true.
REGISTRATION_ENABLED=
# POST /portal/mock/kot/punch: off in production unless true.
KOT_MOCK_ENDPOINT_ENABLED=
# Sanctum API tokens: default 10080 minutes (7 days). Set empty in .env to fall back to config default.
SANCTUM_TOKEN_EXPIRATION_MINUTES=
# Behind nginx/ALB/etc.: proxy IPs (comma-separated) so X-Forwarded-Proto is trusted.
TRUSTED_PROXIES=
# APP_ENV=production で true 推奨（TLS 終端と併用）。ローカルでは false のまま。
FORCE_HTTPS=
# 管理者の Web セッションで TOTP 2FA の登録を必須にする（true は本番導入前に運用調整推奨）。
ENFORCE_ADMIN_2FA=
# 管理者登録時に保存する社内ポータル利用規程・個人情報取り扱い説明のバージョン。
INTERNAL_POLICY_VERSION=2026-05-12
# API: 管理者かつ 2FA 済みは POST /api/auth/login → meta.login_ticket を添えて POST /api/auth/login/two-factor。
# ブラウザから別オリジンの API を叩く場合、CSP connect-src に許可する HTTPS オリジン（カンマ区切り）。
CSP_CONNECT_SRC_EXTRA=

# --- External integrations (mock/optional) ---
# チャット通知は Discord Webhook のみ（業務依頼・昼休憩割当/終了など）
DISCORD_WEBHOOK_URL=
# 互換: 未設定時のみ旧キーを参照（Google Chat 廃止後も URL をこちらに置いていた場合用）
GOOGLE_CHAT_WEBHOOK_URL=
KOT_MOCK_URL=
KOT_API_TOKEN=
GAS_DUMMY_URL=
# 監査ログ用 Web アプリ URL（未設定なら GAS_DUMMY_URL を使用）
GAS_AUDIT_LOG_URL=
# ID/パス管理（一覧 pull・保存 push）。未設定なら GAS_DUMMY_URL
GAS_CREDENTIALS_URL=
# 昼休憩表の GAS 同期（event: lunch_schedule_sync）
GAS_LUNCH_SCHEDULE_URL=
# Required when APP_ENV=production and any GAS_*_URL is set (requests are refused otherwise).
GAS_SIGNING_SECRET=
