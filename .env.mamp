APP_NAME=LOM-SalesHub
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8888

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# MAMP: すぐ動かす用途はSQLite推奨（migrateだけでOK）
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# MAMP: avoid DB-backed state
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

VITE_APP_NAME="${APP_NAME}"

# --- External integrations (mock/optional) ---
DISCORD_WEBHOOK_URL=""

